# Embedded Compute Programs Registry
# Each entry consists of:
#   - An ENUM_NAME line (uppercase identifier for the program)
#   - One or more indented shader file paths (lines with '/' and '.' are files)
# Entries are separated by blank lines.
# Lines starting with # are comments and are ignored.

# Add your compute programs below, following the format above:
# MY_COMPUTE_PROGRAM
#     vclib/shaders/my_compute/cs_my_compute.sc

BUFFER_TO_TEX
    vclib/shaders/utils/cs_buffer_to_tex.sc

CUBEMAP_MIPMAP_GEN
    vclib/shaders/drawable/drawable_environment/cs_cubemap_mipmap_gen.sc

CUBEMAP_TO_IRRADIANCE
    vclib/shaders/drawable/drawable_environment/cs_cubemap_to_irradiance.sc

CUBEMAP_TO_SPECULAR
    vclib/shaders/drawable/drawable_environment/cs_cubemap_to_specular.sc

HDR_EQUIRECT_TO_CUBEMAP
    vclib/shaders/drawable/drawable_environment/cs_hdr_equirect_to_cubemap.sc

IBL_LOOKUP_TEXTURE_GEN
    vclib/shaders/drawable/drawable_environment/cs_ibl_lookup_texture_gen.sc

SELECTION_ALL
    vclib/shaders/selection/cs_selection_all.sc

SELECTION_NONE
    vclib/shaders/selection/cs_selection_none.sc

SELECTION_INVERT
    vclib/shaders/selection/cs_selection_invert.sc

SELECTION_VERTEX
    vclib/shaders/selection/cs_selection_vertex.sc

SELECTION_FACE
    vclib/shaders/selection/cs_selection_face.sc

SELECTION_FACE_VISIBLE
    vclib/shaders/selection/face_visible/cs_face_visible.sc
