@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/vclibTargets.cmake")

# --- Dynamic Optional Dependencies ---

# 1. TBB
if (UNIX)
    find_package(Threads QUIET)
    find_package(TBB QUIET)

    if (TARGET TBB::tbb AND TARGET Threads::Threads)
        if (TARGET vclib::vclib-core)
            set_property(TARGET vclib::vclib-core APPEND PROPERTY INTERFACE_LINK_LIBRARIES TBB::tbb Threads::Threads)
        endif()
        
        # Remove poolstl fallback macros if present
        if (TARGET vclib::vclib-3rd-poolstl)
            get_property(poolstl_defs TARGET vclib::vclib-3rd-poolstl PROPERTY INTERFACE_COMPILE_DEFINITIONS)
            if (poolstl_defs)
                list(REMOVE_ITEM poolstl_defs "POOLSTL_STD_SUPPLEMENT_NO_INCLUDE" "POOLSTL_STD_SUPPLEMENT_FORCE")
                set_property(TARGET vclib::vclib-3rd-poolstl PROPERTY INTERFACE_COMPILE_DEFINITIONS "${poolstl_defs}")
            endif()
        endif()
    endif()
endif()

# 2. Qt6
find_package(Qt6 6.7 COMPONENTS Core Gui QUIET)
if (TARGET Qt6::Core AND TARGET Qt6::Gui)
    if (TARGET vclib::vclib-core)
        set_property(TARGET vclib::vclib-core APPEND PROPERTY INTERFACE_COMPILE_DEFINITIONS VCLIB_WITH_QT)
        set_property(TARGET vclib::vclib-core APPEND PROPERTY INTERFACE_LINK_LIBRARIES Qt6::Core Qt6::Gui)
    endif()
endif()

check_required_components(vclib)
