function(vclib_generate_shader_combinations_recursive DIMS_REMAINING CURRENT_COMBINATION CURRENT_DEFINES CONFIG_VARS)
    list(LENGTH DIMS_REMAINING NUM_DIMS)
    
    if (NUM_DIMS EQUAL 0)
        # CONFIG_VARS format: CONFIG_DIR;FS_IN;FS_PREFIX;DEFINE_PREFIX;COMBO_OUT_FILE;ENUM_PREFIX;VS_FILE
        list(GET CONFIG_VARS 0 CONFIG_DIR)
        list(GET CONFIG_VARS 1 FS_IN)
        list(GET CONFIG_VARS 2 FS_PREFIX)
        list(GET CONFIG_VARS 3 DEFINE_PREFIX)
        list(GET CONFIG_VARS 4 COMBO_OUT_FILE)
        list(GET CONFIG_VARS 5 ENUM_PREFIX)
        list(GET CONFIG_VARS 6 VS_FILE)
        
        string(TOLOWER "${CURRENT_COMBINATION}" COMBINATION_LC)
        string(TOUPPER "${CURRENT_COMBINATION}" COMBINATION_UC)
        
        set(FS_OUT_NAME "${FS_PREFIX}${COMBINATION_LC}.sc")
        set(FS_OUT_PATH "${CONFIG_DIR}/${FS_OUT_NAME}")
        # Generate the file content
        set(FS_CONTENT "// Auto-generated by vclib_generate_shaders_from_config\n")
        string(APPEND FS_CONTENT "${CURRENT_DEFINES}\n")
        string(APPEND FS_CONTENT "#include \"${FS_IN}\"\n")
        
        set(FS_OUT_PATH "${BIN_CONFIG_DIR}/${FS_PREFIX}${COMBINATION_LC}.sc")
        file(WRITE "${FS_OUT_PATH}" "${FS_CONTENT}")
        
        # Determine the relative paths for the config output
        # For VS_FILE, it's still in SOURCE_DIR
        file(RELATIVE_PATH VS_REL_PATH "${CMAKE_CURRENT_SOURCE_DIR}/shaders" "${CONFIG_DIR}/${VS_FILE}")
        # For FS_OUT_PATH, it's in BINARY_DIR
        file(RELATIVE_PATH FS_REL_PATH "${CMAKE_CURRENT_BINARY_DIR}/shaders" "${FS_OUT_PATH}")
        
        # Replace vclib/bgfx with vclib/shaders so they match what vclib_add_embedded_programs_from_file expects
        string(REPLACE "vclib/bgfx/" "vclib/shaders/" VS_REL_PATH "${VS_REL_PATH}")
        string(REPLACE "vclib/bgfx/" "vclib/shaders/" FS_REL_PATH "${FS_REL_PATH}")
        
        # Write to combo out file
        file(APPEND "${COMBO_OUT_FILE}" "${ENUM_PREFIX}${COMBINATION_UC}\n")
        file(APPEND "${COMBO_OUT_FILE}" "    ${VS_REL_PATH}\n")
        file(APPEND "${COMBO_OUT_FILE}" "    ${FS_REL_PATH}\n\n")
        
        return()
    endif()
    
    # Get the first dimension
    list(GET DIMS_REMAINING 0 FIRST_DIM)
    list(REMOVE_AT DIMS_REMAINING 0)
    
    # Get values for this dimension from parent scope
    set(VALUES "${VALUES_${FIRST_DIM}}")
    
    foreach(VAL IN LISTS VALUES)
        # Append dimension to combination name: e.g. "_shading_flat"
        string(TOLOWER "${FIRST_DIM}" DIM_LC)
        string(TOLOWER "${VAL}" VAL_LC)
        
        set(NEW_COMBINATION "${CURRENT_COMBINATION}_${DIM_LC}_${VAL_LC}")
        
        list(GET CONFIG_VARS 3 DEFINE_PREFIX)
        string(TOUPPER "${FIRST_DIM}" DIM_UC)
        string(TOUPPER "${VAL}" VAL_UC)
        
        set(NEW_DEFINES "${CURRENT_DEFINES}#define ${DEFINE_PREFIX}_${DIM_UC}_${VAL_UC} 1\n")
        
        vclib_generate_shader_combinations_recursive(
            "${DIMS_REMAINING}" 
            "${NEW_COMBINATION}" 
            "${NEW_DEFINES}" 
            "${CONFIG_VARS}"
        )
    endforeach()
endfunction()

# vclib_generate_shaders_from_config(CONFIG_FILE)
function(vclib_generate_shaders_from_config CONFIG_FILE)
    if(NOT EXISTS "${CONFIG_FILE}")
        message(FATAL_ERROR "Config file not found: ${CONFIG_FILE}")
    endif()
    
    get_filename_component(CONFIG_DIR "${CONFIG_FILE}" DIRECTORY)
    
    # We need the relative path of the config file from the source dir to mirror it in binary dir
    file(RELATIVE_PATH CONFIG_REL_PATH "${CMAKE_CURRENT_SOURCE_DIR}" "${CONFIG_DIR}")
    set(BIN_CONFIG_DIR "${CMAKE_CURRENT_BINARY_DIR}/${CONFIG_REL_PATH}")
    
    # Ensure binary output directory exists
    file(MAKE_DIRECTORY "${BIN_CONFIG_DIR}")
    
    set(COMBO_OUT_FILE "${CMAKE_CURRENT_BINARY_DIR}/shaders/embedded_vf_combo_programs.config")
    
    # Initialize the output file
    # We must make sure the directory for combo output exists
    get_filename_component(COMBO_OUT_DIR "${COMBO_OUT_FILE}" DIRECTORY)
    file(MAKE_DIRECTORY "${COMBO_OUT_DIR}")
    file(WRITE "${COMBO_OUT_FILE}" "# Auto-generated combinations from ${CONFIG_FILE}\n\n")
    
    # Initialize variables
    set(ENUM_PREFIX "")
    set(DEFINE_PREFIX "")
    set(VS_FILE "")
    set(FS_IN "")
    set(FS_PREFIX "")
    
    set(DIMS "")
    set(CURRENT_DIM "")
    
    file(STRINGS "${CONFIG_FILE}" FILE_LINES)
    
    foreach(LINE IN LISTS FILE_LINES)
        # Skip empty or whitespace-only lines
        if("${LINE}" MATCHES "^[ \t]*$")
            set(CURRENT_DIM "")
            continue()
        endif()
        
        # Skip comments
        if("${LINE}" MATCHES "^[ \t]*#")
            continue()
        endif()
        
        # If line starts with whitespace, it's a value for the current dimension
        if("${LINE}" MATCHES "^[ \t]+([^ \t].*)")
            string(STRIP "${LINE}" VAL)
            if(NOT "${CURRENT_DIM}" STREQUAL "")
                list(APPEND VALUES_${CURRENT_DIM} "${VAL}")
            else()
                message(WARNING "Found value '${VAL}' outside of any dimension in ${CONFIG_FILE}")
            endif()
        else()
            string(STRIP "${LINE}" STRIPPED_LINE)
            
            if("${STRIPPED_LINE}" MATCHES "^ENUM_PREFIX (.+)")
                set(ENUM_PREFIX "${CMAKE_MATCH_1}")
            elseif("${STRIPPED_LINE}" MATCHES "^DEFINE_PREFIX (.+)")
                set(DEFINE_PREFIX "${CMAKE_MATCH_1}")
            elseif("${STRIPPED_LINE}" MATCHES "^VS_FILE (.+)")
                set(VS_FILE "${CMAKE_MATCH_1}")
            elseif("${STRIPPED_LINE}" MATCHES "^FS_IN (.+)")
                set(FS_IN "${CMAKE_MATCH_1}")
            elseif("${STRIPPED_LINE}" MATCHES "^FS_PREFIX (.+)")
                set(FS_PREFIX "${CMAKE_MATCH_1}")
            else()
                # It's a new dimension
                set(CURRENT_DIM "${STRIPPED_LINE}")
                list(APPEND DIMS "${CURRENT_DIM}")
                set(VALUES_${CURRENT_DIM} "")
            endif()
        endif()
    endforeach()
    
    if (NOT FS_IN OR NOT FS_PREFIX)
        message(FATAL_ERROR "Missing FS_IN or FS_PREFIX in ${CONFIG_FILE}")
    endif()
    
    set(CONFIG_VARS "${CONFIG_DIR}" "${FS_IN}" "${FS_PREFIX}" "${DEFINE_PREFIX}" "${COMBO_OUT_FILE}" "${ENUM_PREFIX}" "${VS_FILE}")
    
    vclib_generate_shader_combinations_recursive(
        "${DIMS}"
        ""
        ""
        "${CONFIG_VARS}"
    )
    
    message(STATUS "Generated shaders from ${CONFIG_FILE}")
    
    # Store the config file in a variable so it can be added to the IDE sources
    set(VCLIB_GENERATED_SHADER_CONFIGS ${VCLIB_GENERATED_SHADER_CONFIGS} "${CONFIG_FILE}" PARENT_SCOPE)
endfunction()

# vclib_generate_all_shaders_from_configs(DIR_PATH)
# Recursively finds all .config files in the given directory and calls vclib_generate_shaders_from_config on each
function(vclib_generate_all_shaders_from_configs DIR_PATH)
    file(GLOB_RECURSE ALL_CONFIGS "${DIR_PATH}/*.config")
    foreach(CONFIG_FILE ${ALL_CONFIGS})
        vclib_generate_shaders_from_config("${CONFIG_FILE}")
    endforeach()
    
    # Propagate the collected config files to the parent scope
    set(VCLIB_GENERATED_SHADER_CONFIGS ${VCLIB_GENERATED_SHADER_CONFIGS} PARENT_SCOPE)
endfunction()
